{
  "name": "alan-vault",
  "version": "2.0.0",
  "description": "Alan Vault - Secure Cloud Platform for Modern Workspace",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run build:css && npm run build:js",
    "build:css": "postcss css/*.css -d public/css",
    "build:js": "webpack --mode production",
    "watch": "webpack --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "clean": "rm -rf node_modules package-lock.json",
    "setup": "npm install && npm run build",
    "backup": "node scripts/backup.js",
    "maintenance:on": "node scripts/maintenance.js on",
    "maintenance:off": "node scripts/maintenance.js off",
    "db:backup": "node scripts/db-backup.js",
    "db:restore": "node scripts/db-restore.js",
    "logs:clean": "node scripts/clean-logs.js",
    "health": "node scripts/health-check.js",
    "docker:build": "docker build -t alanvault:latest .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "deploy:prod": "git pull && npm install && npm run build && pm2 restart alanvault",
    "deploy:staging": "git checkout staging && git pull && npm install && npm run build && pm2 restart alanvault-staging"
  },
  "keywords": [
    "cloud-storage",
    "file-management",
    "notes",
    "tasks",
    "bookmarks",
    "productivity",
    "secure",
    "encryption",
    "pwa",
    "offline-first"
  ],
  "author": "Alan Vault Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alanvault/alanvault.git"
  },
  "bugs": {
    "url": "https://github.com/alanvault/alanvault/issues"
  },
  "homepage": "https://alanvault.com",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.7.0",
    "multer": "^1.4.5-lts.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "dotenv": "^16.0.3",
    "compression": "^1.7.4",
    "express-session": "^1.17.3",
    "connect-redis": "^6.1.3",
    "redis": "^4.6.5",
    "mysql2": "^3.2.0",
    "sequelize": "^6.31.1",
    "mongoose": "^7.0.3",
    "nodemailer": "^6.9.1",
    "express-validator": "^6.15.0",
    "csurf": "^1.11.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "socket.io": "^4.6.1",
    "multer-s3": "^3.0.1",
    "aws-sdk": "^2.1400.0",
    "sharp": "^0.32.0",
    "archiver": "^5.3.1",
    "mime-types": "^2.1.35",
    "uuid": "^9.0.0",
    "express-rate-limit": "^6.7.0",
    "express-slow-down": "^2.0.1",
    "helmet": "^7.0.0",
    "xss": "^1.0.14",
    "crypto-js": "^4.1.1",
    "node-cron": "^3.0.2",
    "winston": "^3.8.2",
    "winston-daily-rotate-file": "^4.7.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^4.6.2",
    "pm2": "^5.3.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "eslint": "^8.39.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.27.5",
    "prettier": "^2.8.8",
    "webpack": "^5.80.0",
    "webpack-cli": "^5.0.2",
    "postcss": "^8.4.23",
    "postcss-cli": "^10.1.0",
    "autoprefixer": "^10.4.14",
    "cssnano": "^6.0.0",
    "@babel/core": "^7.21.4",
    "@babel/preset-env": "^7.21.4",
    "babel-loader": "^9.1.2",
    "cross-env": "^7.0.3"
  }
}